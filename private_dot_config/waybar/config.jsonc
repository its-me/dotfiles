// -*- mode: jsonc -*-
{
    // "layer": "top", // Waybar at top layer
    // "position": "bottom", // Waybar position (top|bottom|left|right)
    "height": 24, // Waybar height (to be removed for auto height)
    // "width": 1280, // Waybar width
    "spacing": 4, // Gaps between modules (4px)
    // Choose the order of the modules
    "modules-left": [
        "niri/workspaces"
    ],
    "modules-right": [
        "idle_inhibitor",
        "custom/updates",
        "custom/claude",
        "load",
        "cpu",
        "memory",
        "disk",
        "wireplumber",
        "wireplumber#source",
        "network",
        // "temperature",
        "backlight",
        // "power-profiles-daemon",
        "battery",
        "niri/language",
        "clock",
        "tray",
        "custom/power"
    ],
    // Modules configuration
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "яБо ",
            "deactivated": "яБ░ "
        }
    },
    "custom/claude": {
        "format": "{}",
        "interval": 60,
        "exec": "claude-usage --waybar",
        "return-type": "json",
        "exec-if": "command -v claude-usage",
        "signal": 9,
        "on-click": "pkill -SIGRTMIN+9 waybar"
    },
    "custom/updates": {
      "format": "{}",
      "interval": 10800,
      "exec": "~/.config/waybar/arch_updates.sh",
      "return-type": "json",
      "exec-if": "exit 0",
      "signal": 8
    },
    "load": {
      "interval": 1,
      "format": "яГд  {load1} {load5} {load15}"
    },
    "cpu": {
        "format": "яЛЫ  {usage}%",
        "tooltip": false
    },
    "memory": {
        "format": "ю┐Е  {}%"
    },
    "disk": {
      "interval": 5,
      "format": "яВа  {specific_free:0.2f}",
      "tooltip-format": "{specific_used:0.2f} GB used out of {specific_total:0.2f} GB on {path} ({percentage_used}%)",
      "path": "/",
      "unit": "GB"
    },
    "temperature": {
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}┬░C {icon}",
        "format": "{temperatureC}┬░C {icon}",
        "format-icons": ["яЭл", "яЛЙ", "яЭй"]
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{icon} {percent}%",
        "format-icons": ["юОН", "юПУ", "юПС", "юПП", "юПО", "юПН", "юПК", "юПИ", "юОЫ"]
    },
   "power-profiles-daemon": {
      "format": "{icon}",
      "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
      "tooltip": true,
      "format-icons": {
        "default": "яГз",
        "performance": "яГз",
        "balanced": "яЙО",
        "power-saver": "яБм"
      }
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "яЗл  {signalStrength}%",
        "tooltip-format": "ґ▒Ъ╛  {essid}",
        "format-disconnected": "ґ░Цк Off",
    },
    "wireplumber": {
      "node-type": "Audio/Sink",
      "format": "{icon}  {volume}%",
      "format-muted": "ю╗и  {volume}%",
      "format-icons": ["яАж", "яАз", "яАи"],
      "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
      "max-volume": 150,
      "scroll-step": 5
    },
    "wireplumber#source": {
      "node-type": "Audio/Source",
      "format": "ю┤Г {volume}%",
      "format-muted": "ю┐Ж  {volume}%",
      "on-click": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
      "max-volume": 150,
      "scroll-step": 5
    },
    "battery": {
       "states": {
           // "good": 95,
           "warning": 30,
           "critical": 15
       },
       "format": "{icon} {capacity}%",
       "format-full": "{icon} {capacity}%",
       "format-charging": "ґ░ВД {capacity}%",
       "format-plugged": "ґ▒Яв {capacity}%",
       "format-alt": "{icon} {time}",
       // "format-good": "", // An empty format will hide the module
       // "format-full": "",
       // "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
       "format-icons": ["ґ░ВО", "ґ░Б║", "ґ░Б╗", "ґ░Б╝", "ґ░Б╜", "ґ░Б╛", "ґ░Б┐", "ґ░ВА", "ґ░ВБ", "ґ░ВВ", "ґ░Б╣"]
    },
    "niri/language": {
      // "format": "ґ░ММ {}",
      "format-en": "ґ░ММ En ",
      "format-ru": "ґ░ММ Ru "
    },
    "clock": {
        "interval": 1,
        "format": "ґ░еФ {:%Y-%m-%d %H:%M:%S}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>"
//        "calendar": {
//          "mode": "month",
//          "on-scroll": 1
//        }
    },
    "tray": {
        "icon-size": 18,
        // "spacing": 10,
        // "icons": {
        //   "blueman": "bluetooth",
        //   "TelegramDesktop": "$HOME/.local/share/icons/hicolor/16x16/apps/telegram.png"
        // }
    },
    "custom/power": {
        "format" : "тП╗ ",
		"tooltip": false,
		"menu": "on-click",
		"menu-file": "$HOME/.config/waybar/power_menu.xml", // Menu file in resources folder
		"menu-actions": {
			"shutdown": "shutdown",
			"reboot": "reboot"
		}
    }
}
